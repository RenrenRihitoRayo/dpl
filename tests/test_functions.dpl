&use {std/text_io.py}

fn fib(n)
    set a = 1
    set b = 0
    while (:n > 0)
        set c = [:a + :b]
        set b = :a
        set a = :c
        dec n
    end

    return :b
end

happy_assert [fib!(10) == 55]

object test
method test.new(value)
    new :self tmp
    set self.value = :value
    return :tmp
end
method test.get_value()
    return :self.value
end

set obj = test.new!(90)
happy_assert [test.get_value!() == 90]
