&use {std/text_io.py}

switch :_meta.internal.os_name_general
    case "nt"
        io:println("Hello, windows!")
    end
    case "posix"
        io:println("Hello, linux enthusiasts!\n... or MacOS users.")
    end
    case "jython"
        io:println("At this point just use pypy.")
    end
    default
        io:println("System not recognized:", :_meta.os_name)
    end
end
